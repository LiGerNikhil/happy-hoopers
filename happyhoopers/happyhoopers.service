[Unit]
Description=Happy Hoopers Django Application
After=network.target

[Service]
Type=notify
User=www-data
Group=www-data
WorkingDirectory=/var/www/happyhoopers
Environment="PATH=/var/www/happyhoopers/venv/bin"
ExecStart=/var/www/happyhoopers/venv/bin/gunicorn -c gunicorn_config.py happyhoopers.wsgi:application
ExecReload=/bin/kill -s HUP $MAINPID
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
